@model cloud2.Models.UserModel

@{
    ViewData["Title"] = "View";
}

<div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-controller="Account" asp-action="SubmitChangePassword" method="post" class="mt-5 d-flex flex-column justify-content-start align-items-center">
                <h1 class="display-4 text-center mb-3">Zarejestuj się</h1>
                <div class="mb-3 w-100">
                    <div class="position-relative">
                        <i class="fa-solid fa-lock faicon"></i>
                        <input type="password" class="form-control inputawesome" name="Password" placeholder="Podaj nowe hasło">
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3 w-100">
                    <div class="position-relative">
                        <i class="fa-solid fa-lock faicon"></i>
                        <input type="password" class="form-control inputawesome" name="Ppassword" placeholder="Powtórz nowe hasło">
                    </div>
                    <span asp-validation-for="Ppassword" class="text-danger"></span>
                </div>


                <div class="text-center mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">Zmień hasło</button>
                </div>
            </form>
        </div>
    </div>

    <form asp-controller="Home" asp-action="GoToAccount" class="text-center">
        <button type="submit" class="btn btn-outline-primary btn-lg">Powrót do szczegółów konta</button>
    </form>

</div>