@model UserModel
@{

    ViewData["Title"] = "Login";

}


<div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-controller="Login" asp-action="SubmitLogin" method="post"  class="mt-5 d-flex flex-column justify-content-start align-items-center">
                <h1 class="display-4 text-center mb-3">Zaloguj się</h1>
                <div class="mb-3 w-100">
                    <div class="position-relative">
                        <i class="fa-solid fa-user faicon"></i>
                        <input type="text" class="form-control inputawesome" name="Username" aria-describedby="Username" placeholder="Login" maxlength="20">
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3 w-100">
                    <div class="position-relative ">
                        <i class="fa-solid fa-lock faicon"></i>
                        <input type="password" class="form-control inputawesome" name="Password" placeholder="Password" maxlength="20">
                    </div>
                <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="text-center mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">Zaloguj</button>
                </div>
            </form>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-controller="Home" asp-action="GoToRegister" class="text-center">
                <button type="submit" class="btn btn-outline-primary btn-lg">Nie masz konta? Zarejestruj się!</button>
            </form>
        </div>
    </div>
</div>





