@model FileViewModel

@{
    ViewData["Title"] = "FileAdd";
}

<h1>Dodaj Plik</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-controller="File" asp-action="SubmitFileAdd" method="post" enctype="multipart/form-data">


            <div class="mb-3 w-100">
                <div class="position-relative">
                    <i class="fa-solid fa-file faicon"></i>   
                    <input type="text" class="form-control inputawesome" name="Name" placeholder="Nazwa pliku" maxlength="20">
                </div>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
           
            <div>
                <label for="uploadedFile">Wybierz plik</label>
                <input type="file" name="formFile" class="form-control" />
                <span asp-validation-for="formFile" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Dodaj" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <div>
        <form asp-controller="Home" asp-action="GoToFile" class="mt-3">
            <button type="submit" class="btn btn-outline-primary btn-lg">Wróć to twoich plików</button>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
